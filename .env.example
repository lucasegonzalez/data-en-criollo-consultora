# Traefik (Block 1 — required before docker compose up)
CF_DNS_API_TOKEN=change_me
TRAEFIK_USER=admin
TRAEFIK_PASS_HASH=$(openssl passwd -apr1 your_password_here)
DOMAIN=consultora.example.com

# FastAPI (Block 2)
DATABASE_URL=sqlite:///data/consultora.db
JWT_SECRET=change_me_to_a_random_secret
API_PORT=8000
API_DOMAIN=api.consultora.example.com

# Hermes (Block 2)
HERMES_API_KEY=change_me
WHATSAPP_TOKEN=change_me
TELEGRAM_TOKEN=change_me

# n8n (Block 3)
N8N_USER=admin
N8N_PASSWORD=change_me

# Backblaze B2 (Block 3)
B2_BUCKET=consultora-backups
B2_APP_KEY_ID=
B2_APP_KEY=
